{
  "name": "QuantumVault",
  "version": "2.0.0",
  "type": "module",
  "engines": {
    "node": ">=24.14.0",
    "npm": ">=11.9.0"
  },
  "packageManager": "npm@11.9.0",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "node scripts/build.mjs",
    "selftest": "node scripts/selftest.mjs",
    "schema:fixtures": "node scripts/schema-fixtures.mjs",
    "corpus:verify": "node scripts/corpus-verify.mjs",
    "check": "npm run selftest && npm run schema:fixtures && npm run build",
    "deploy": "npm run build"
  },
  "dependencies": {
    "@noble/hashes": "2.2.0",
    "@noble/post-quantum": "0.6.1",
    "shamir-secret-sharing": "0.0.4"
  },
  "devDependencies": {
    "esbuild": "0.28.0"
  }
}
